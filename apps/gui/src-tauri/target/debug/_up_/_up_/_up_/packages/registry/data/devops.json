{
  "docker": {
    "name": "Docker",
    "description": "Platform for developing, shipping, and running applications",
    "category": "devops",
    "enabled": false,
    "default": false,
    "platforms": {
      "linux": {
        "script": "packages/os-linux/scripts/docker.sh",
        "method": "apt"
      },
      "windows": {
        "script": "packages/os-windows/scripts/docker.ps1",
        "method": "choco"
      },
      "macos": {
        "script": "packages/os-macos/scripts/docker.sh",
        "method": "brew"
      }
    },
    "post_install": [
      "docker_config",
      "docker_user_group"
    ],
    "config_file": "packages/os-linux/scripts/docker-config.sh"
  },
