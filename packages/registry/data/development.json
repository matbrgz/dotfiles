{
  "nodejs": {
    "name": "Node.js",
    "description": "JavaScript runtime built on Chrome's V8 engine",
    "category": "development",
    "enabled": false,
    "default": false,
    "platforms": {
      "linux": {
        "script": "packages/os-linux/scripts/nodejs.sh",
        "method": "apt"
      },
      "windows": {
        "script": "packages/os-windows/scripts/nodejs.ps1",
        "method": "choco"
      },
      "macos": {
        "script": "packages/os-macos/scripts/nodejs.sh",
        "method": "brew"
      }
    },
    "post_install": [
      "nvm_install"
    ],
