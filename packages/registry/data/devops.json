{
  "docker": {
    "name": "Docker",
    "description": "Platform for developing, shipping, and running applications",
    "category": "devops",
    "enabled": false,
    "default": false,
    "platforms": {
      "linux": {
        "script": "packages/os-linux/scripts/docker.sh",
        "method": "apt"
      },
      "windows": {
        "script": "packages/os-windows/scripts/docker.ps1",
        "method": "choco"
      },
      "macos": {
        "method": "brew-cask",
        "cask": "docker"
      }
    },
    "post_install": [
      "docker_config"
    ]
  },
  "flyctl": {
    "name": "Fly.io CLI",
    "description": "Command line tool for Fly.io platform",
    "category": "devops",
    "enabled": true,
    "default": true,
    "platforms": {
      "macos": {
        "method": "brew",
        "formula": "flyctl"
      }
    },
    "post_install": []
  },
  "gcloud": {
    "name": "Google Cloud CLI",
    "description": "Command-line interface for Google Cloud",
    "category": "devops",
    "enabled": true,
    "default": false,
    "platforms": {
      "macos": {
        "method": "brew-cask",
        "cask": "gcloud-cli"
      }
    },
    "post_install": []
  },
  "android-tools": {
    "name": "Android CLI Tools",
    "description": "Android command line and platform tools",
    "category": "devops",
    "enabled": true,
    "default": false,
    "platforms": {
      "macos": {
        "method": "brew-cask",
        "cask": ["android-commandlinetools", "android-platform-tools"]
      }
    },
    "post_install": []
  },
  "terraform": {
    "name": "Terraform",
    "description": "Infrastructure as Code tool",
    "category": "devops",
    "enabled": false,
    "default": false,
    "platforms": {
      "linux": {
        "script": "packages/os-linux/scripts/terraform.sh",
        "method": "apt"
      },
      "windows": {
        "script": "packages/os-windows/scripts/terraform.ps1",
        "method": "choco"
      },
      "macos": {
        "method": "brew",
        "formula": "terraform"
      }
    },
    "post_install": []
  }
}
