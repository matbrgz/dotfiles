{
  "git": {
    "name": "Git",
    "description": "Distributed version control system",
    "category": "essential",
    "enabled": true,
    "default": true,
    "platforms": {
      "linux": {
        "script": "packages/os-linux/scripts/git.sh",
        "method": "apt"
      },
      "windows": {
        "script": "packages/os-windows/scripts/git.ps1",
        "method": "choco"
      },
      "macos": {
        "script": "packages/os-macos/scripts/git.sh",
        "method": "brew"
      }
    },
    "post_install": [
      "git_config"
    ],
    "config_file": "packages/os-linux/scripts/git-config.sh"
  },
