{
  "name": "dotfiles-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^8.0.0",
    "turbo": "^1.10.0",
    "typescript": "^5.0.0"
  }
}
